# Database
# Copy this file to backend/.env and set a URL that matches YOUR Postgres install.
#
# Common mistake: user "postgres" with password "postgres" — only works if you
# actually set that password when you installed PostgreSQL on Windows.
# Otherwise use the password you chose in the installer, or create a dev user:
#   psql -U postgres -f prisma/dev-local-postgres.sql
# then:
#   DATABASE_URL="postgresql://izum:izum_local_dev@localhost:5432/izum?schema=public"
#
# After DATABASE_URL is correct:
#   npx prisma db push && npm run prisma:seed
DATABASE_URL="postgresql://username:password@localhost:5432/izum?schema=public"

# Redis
# Used for WebSockets, pub/sub telemetry, and session state
REDIS_URL="redis://localhost:6379"

# Security
# Generate a secure random string (e.g., node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your_super_secret_jwt_key_here"
